# Copie para .env e preencha os valores. Não versionar .env.

# Render — API Key (Account → API Keys). Usado por: npm run render:status
# RENDER_API_KEY=
# Opcional se o nome do web service não for byla-backend:
# RENDER_SERVICE_NAME=byla-backend

PORT=3001
CORS_ORIGIN=http://localhost:5174

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_FLUXO_ID=
# Planilha Google para export n8n (webhook transacoes → aba Movimentações) — mesmo ID pode ser referenciado no n8n como GOOGLE_SHEETS_ENTRADA_SAIDA_ID
GOOGLE_SHEETS_ENTRADA_SAIDA_ID=
# Com espaço no nome da aba use aspas simples na notação A1 (ou deixe sem aspas; o backend normaliza)
GOOGLE_SHEETS_FLUXO_RANGE='MARÇO 26'!A:Z
# Caminho do JSON da service account (ou use GOOGLE_SHEETS_CREDENTIALS_JSON). Necessário escrita para npm run sync:entrada-saida
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Segredo para POST /api/planilha-entrada-saida/sync (header X-Byla-Sync-Secret)
# BYLA_SYNC_SECRET=

# n8n — Public API (opcional; Settings → n8n API). Usado por npm run n8n:list-workflows
# N8N_BASE_URL=https://n8n.espacobyla.online
# N8N_API_KEY=

# Regras de negócio (opcional)
# Abas elegíveis para conciliação/pagamentos (separadas por vírgula)
BYLA_ELIGIBLE_SHEETS=BYLA DANÇA,PILATES,PILATES MARINA,TEATRO,YOGA,G.R.,TEATRO INFANTIL
# Janela em dias para buscar transações do banco ao redor da data de pagamento
BYLA_BANCO_JANELA_DIAS=7
# Tolerância de valor para match planilha x banco
BYLA_MATCH_VALOR_TOLERANCIA=0.01
# Dias de tolerância após vencimento para considerar "em dia"
BYLA_GRACE_DIAS_APOS_VENCIMENTO=5
# Entradas externas ignoradas no extrato oficial (prefixos/trechos, vírgula)
BYLA_EXTERNAL_ENTRIES=EA ,BLEAD AD TECH
# Prefixo do nome de saída vinculada às entradas externas
BYLA_SAMUEL_NAME_PREFIX=samuel davi tude silva
# Tolerância (R$) para parear entrada EA/Blead com saída Samuel no mesmo dia
BYLA_EXTERNAL_PAIR_TOLERANCE=800
# Saídas com nome Samuel nesta faixa são sempre excluídas do extrato oficial (repasse ~5k)
BYLA_SAMUEL_REPASSE_VALOR_MIN=4800
BYLA_SAMUEL_REPASSE_VALOR_MAX=6500

# Funcionários + subempresa Byla Dança (match em planilhas). Opcional: JSON substitui a lista padrão do código.
# Ex.: [{"nome":"Nilson","funcao":"Equipe","aliases":["NILSON"]},{"nome":"BylaDança","funcao":"Subempresa","aliases":["BYLA DANÇA"],"subempresa":true}]
# BYLA_FUNCIONARIOS_JSON=

# IA – Relatórios (pode usar uma ou mais; ordem: Gemini → Groq → OpenAI)
# Grátis: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Grátis, cota alta: https://console.groq.com/keys
GROQ_API_KEY=
# Pago
# OPENAI_API_KEY=
