# anon key: Supabase → Project Settings → API → Project API Keys → anon public

VITE_SUPABASE_URL=https://flbimmwxxsvixhghmmfu.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Backend (dados completos: alunos, modalidades, pendências). Opcional; se vazio, telas usam só Supabase.
# Local: http://localhost:3001
# Produção (Render): https://byla-backend.onrender.com — sem barra no fim
VITE_BACKEND_URL=
