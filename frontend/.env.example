# Supabase – Painel Byla
# Copie para .env e preencha com os valores do seu projeto Supabase.
# Project URL: Supabase → Project Settings → API → Project URL
# anon key: Supabase → Project Settings → API → Project API Keys → anon public

VITE_SUPABASE_URL=https://flbimmwxxsvixhghmmfu.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
# URL pública do painel (sem barra no fim). Obrigatório para o link "Esqueci minha senha" bater com o Supabase.
# Local: http://localhost:5173  |  Produção: https://seu-dominio.com
# No Supabase: Authentication → URL Configuration → adicione em "Redirect URLs":
#   http://localhost:5173/redefinir-senha
#   https://seu-dominio.com/redefinir-senha
VITE_SITE_URL=http://localhost:5173
# Quando o backend estiver com BYLA_AUTH_ENFORCE=true, o frontend envia automaticamente
# o access_token da sessão Supabase no header Authorization.

# Backend (dados completos: alunos, modalidades, pendências). Opcional; se vazio, telas usam só Supabase.
# Local: http://localhost:3001
# Produção (Render): https://byla-backend.onrender.com — sem barra no fim
VITE_BACKEND_URL=
